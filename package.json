{
  "name": "b-image-gallery",
  "version": "1.0.0",
  "description": "Create and display photo gallery/photo album.",
  "license": "GPL-2.0-or-later",
  "main": "build/index.js",
  "author": "Wasek Bellah, Himangsu Roy",
  "scripts": {
    "packages-update": "wp-scripts packages-update",
    "lint": "eslint src",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "format": "wp-scripts format",
    "start": "wp-scripts start --webpack-copy-php",
    "build": "wp-scripts build --webpack-copy-php",
    "i18n-pot": "wp i18n make-pot . languages/image-gallery.pot --exclude=\"src\" && cp ./languages/image-gallery.pot ./languages/image-gallery-en_US.po",
    "i18n-json": "wp i18n make-json languages/ --no-purge",
    "i18n-mo": "wp i18n make-mo languages/",
    "i18n": "npm run i18n-pot && npm run i18n-json && npm run i18n-mo",
    "plugin-zip": "wp-scripts plugin-zip",
    "bundle": "npm run lint && npm run build && npm run i18n && npm run plugin-zip"
    
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.525.0",
    "react-datepicker": "^8.4.0",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^7.5.2",
    "swiper": "^11.2.10"
  },
  "devDependencies": {
    "@wordpress/scripts": "^27.9.0",
    "eslint-webpack-plugin": "^4.2.0"
  }
}
